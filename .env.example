# Flower Power — Environment Variables
# Copy this file to .env and fill in the values below.
# NEVER commit .env to Git.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Public anon key — safe to expose in the browser bundle
VITE_SUPABASE_ANON_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Stripe publishable key (e.g. pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe secret key (e.g. sk_test_...) - Server side only, keep secure!
STRIPE_SECRET_KEY=
